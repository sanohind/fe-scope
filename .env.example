# SCOPE Frontend - Production Environment Configuration

# API Configuration

VITE_API_URL=
VITE_SPHERE_SSO_URL=

# SSO Configuration
# Set to 'true' to enable SSO authentication via Sphere
# Set to 'false' to disable SSO and allow direct access (for development/testing)
VITE_ENABLE_SSO=true

# Note: Ganti URL di atas sesuai dengan konfigurasi server production Anda
# When deploying with SSO enabled, set VITE_ENABLE_SSO=true
